---
import Head from '../components/Head.astro';

import Header from '../components/Header.astro';
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Official website of The Fuzztones. Tour dates, music, merch, media, and official links.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <Head title={title} description={description} />
    <style is:global>
      :root {
        color-scheme: dark;
      }

      html {
        font-family: Arial, sans-serif;
        background: #0b0b0b;
        color: #f5f5f5;
      }

      body {
        margin: 0;
      }

      header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid #333;
      }

      nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      nav a {
        color: #f5f5f5;
        text-decoration: none;
      }

      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }

      section {
        margin-bottom: 3rem;
      }

      h1,
      h2 {
        margin-top: 0;
      }

      a {
        color: #f5f5f5;
      }

      .hero {
        text-align: center;
        padding: 6rem 1rem;
        min-height: 60vh;

        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;

        /* background: url('/hero.jpg') center/cover no-repeat; */
      }

      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        /* background: rgba(0, 0, 0, 0.55); */
      }

      .hero > * {
        position: relative;
        z-index: 1;
      }

      .hero h1 {
        font-size: 3rem;
        letter-spacing: 0.1em;
      }

      .hero-sub {
        margin-top: 1rem;
        opacity: 0.7;
      }

      .hero-actions {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        gap: 1.5rem;
      }

      .hero-actions a {
        border: 1px solid #f5f5f5;
        padding: 0.5rem 1.2rem;
        text-decoration: none;
        transition: all 0.2s ease;
      }

      .hero-actions a:hover {
        background: #f5f5f5;
        color: #0b0b0b;
      }
    </style>
  </head>
  <body>
    <Header />
    <slot />
  </body>
</html>
